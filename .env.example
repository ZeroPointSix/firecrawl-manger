FCAM_ADMIN_TOKEN=change_me_admin_token
FCAM_MASTER_KEY=change_me_master_key_32_bytes_minimum____

# SQLite（MVP）
# FCAM_DATABASE__PATH=./data/api_manager.db
# Postgres（生产）
FCAM_DATABASE__URL=postgresql+psycopg://fcam:fcam_password@localhost:5432/fcam

# state.mode=memory|redis
FCAM_STATE__MODE=memory
FCAM_STATE__REDIS__URL=redis://localhost:6379/0
FCAM_STATE__REDIS__KEY_PREFIX=fcam

# /metrics 默认关闭
FCAM_OBSERVABILITY__METRICS_ENABLED=false
